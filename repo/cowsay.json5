{
  description: "A generic test command",
  run: "\
async (args) => {\
    const text = args.join(' ');\
\
    print(` ${'_'.repeat(text.length + 2)}`);\
    print(`< ${text} >`);\
    print(` ${'-'.repeat(text.length + 2)}`);\
    print('        \\   ^__^');\
    print('         \\  (oo)\\_______');\
    print('            (__)\\       )\\/\\');\
    print('                ||----w |');\
    print('                ||     ||');\
}",
}
