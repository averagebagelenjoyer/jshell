{
  description: "A generic test command",
  run: "\
async (args) => {\
    const text = args.join(' ');\
\
    print(String.raw` ${'_'.repeat(text.length + 2)}`);\
    print(String.raw`< ${text} >`);\
    print(String.raw` ${'-'.repeat(text.length + 2)}`);\
    print(String.raw`        \\   ^__^`);\
    print(String.raw`         \\  (oo)\\_______`);\
    print(String.raw`            (__)\\       )\\/\\ `);\
    print(String.raw`                ||----w |`);\
    print(String.raw`                ||     ||`);\
}",
}
